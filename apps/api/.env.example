NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000
# Comma-separated allowed origins, or * for any (dev only). MUST be an explicit
# allow-list in production — the server refuses to boot with '*' when NODE_ENV=production.
APP_ORIGIN=*

# --- Admin bootstrap ---
# The platform admin account, seeded on first boot.
ADMIN_EMAIL=tsenangthatayotlhe04@gmail.com
ADMIN_NAME=PulaCash Admin
# REQUIRED in production (the server refuses to boot without it, and rejects the
# dev default). Locally you can leave it unset to use the dev default password.
# ADMIN_PASSWORD=replace-with-a-strong-unique-password

# Session token lifetime (days) before re-login is required.
SESSION_TTL_DAYS=30

# Observability + abuse protection
LOG_LEVEL=info
# Requests per IP per minute (baseline DoS protection).
RATE_LIMIT_MAX=120
# Set true ONLY when the API runs behind a trusted proxy/load balancer that sets
# X-Forwarded-For. Leaving it false stops direct peers spoofing their IP.
TRUST_PROXY=false

# --- Data ---
# Local dev uses SQLite (created automatically). Leave DATABASE_URL unset locally.
SQLITE_PATH=./pulacash.db
# Production: Supabase Postgres connection string. When set, run db:pg:migrate.
# DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# --- Supabase (Storage / Auth). Service-role key is server-only, never shipped to the client. ---
# SUPABASE_URL=https://[ref].supabase.co
# SUPABASE_ANON_KEY=replace-me
# SUPABASE_SERVICE_ROLE_KEY=replace-me
SUPABASE_STORAGE_BUCKET=student-ids

# --- Upstash Redis (distributed rate limiting). Optional; falls back to in-memory. ---
# UPSTASH_REDIS_REST_URL=https://[ref].upstash.io
# UPSTASH_REDIS_REST_TOKEN=replace-me

# --- Resend (transactional email). Optional; dev logs the code instead. ---
# RESEND_API_KEY=replace-me
EMAIL_FROM=PulaCash <hello@pulacash.app>

ALLOWED_STUDENT_EMAIL_DOMAINS=ub.ac.bw,buan.ac.bw,bac.ac.bw,bitri.co.bw,baisago.ac.bw,botho.ac.bw
